# Optional Hugging Face token.
# The Spanish large-v3 weights (Systran/faster-whisper-large-v3) are public, so
# a token is NOT required. Set one only to avoid anonymous download rate limits,
# or if you later switch to a gated model. Copy this file to `.env` and load it
# into your shell (e.g. `export HF_TOKEN=...`) before running the app.
HF_TOKEN=

# OpenAI API key for the `mind` module (the thinking/LLM faculty).
# Required: mind sends transcribed/typed text to an OpenAI chat model and
# returns its reply. Copy this file to `.env` and paste your key below.
# The .env file is git-ignored, so the key is never committed.
OPENAI_API_KEY=