# Optional Hugging Face token.
# The Spanish large-v3 weights (Systran/faster-whisper-large-v3) are public, so
# a token is NOT required. Set one only to avoid anonymous download rate limits,
# or if you later switch to a gated model. Copy this file to `.env` and load it
# into your shell (e.g. `export HF_TOKEN=...`) before running the app.
HF_TOKEN=

# OpenAI API key for the `mind` module (the thinking/LLM faculty).
# Required: mind sends transcribed/typed text to an OpenAI chat model and
# returns its reply. Copy this file to `.env` and paste your key below.
# The .env file is git-ignored, so the key is never committed.
OPENAI_API_KEY=

# Optional voice effector overrides.
# Runtime clones from baked reference clips (design-once -> clone). Defaults:
# clone model Qwen/Qwen3-TTS-12Hz-1.7B-Base, language Spanish, CUDA when
# available, flash-attention 2 (with safe fallback), cuDNN ON, standard HF cache.

# Runtime (clone) model. Default: Qwen/Qwen3-TTS-12Hz-1.7B-Base
CHRIS_VOICE_MODEL=
# Baking-only (design) model. Default: Qwen/Qwen3-TTS-12Hz-1.7B-VoiceDesign
CHRIS_VOICE_DESIGN_MODEL=
# Hugging Face cache override for voice models.
CHRIS_VOICE_CACHE=
# Synthesis language.
CHRIS_VOICE_LANGUAGE=Spanish
# Torch device map (e.g. cuda:0, cpu). Empty = auto.
CHRIS_VOICE_DEVICE=
# Compute dtype: auto, bfloat16, float16, float32.
CHRIS_VOICE_DTYPE=auto
# Attention implementation. Empty = flash_attention_2 (falls back if missing).
CHRIS_VOICE_ATTN=
# Set to 1 to disable cuDNN (workaround). Default 0 = cuDNN ON.
CHRIS_VOICE_DISABLE_CUDNN=0
# Directory holding baked voice identity. Empty = effectors/effector_voice/identity
CHRIS_VOICE_IDENTITY_DIR=
# Max new audio tokens per synthesis call.
CHRIS_VOICE_MAX_NEW_TOKENS=2048
# Set to 1 to warm up the model at app startup.
CHRIS_VOICE_WARMUP=0
